{
  "buildCommand": "echo 'TypeScript compiled by @vercel/node esbuild'",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ],
  "crons": [
    { "path": "/api/cron/payment-reminders", "schedule": "30 3 * * *" }
  ]
}
