# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0
MONGODB_URI_PROD=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_32_chars
JWT_REFRESH_EXPIRE=7d

# Client URL
CLIENT_URL=http://localhost:3000
ADMIN_CLIENT_URL=http://localhost:3000/admin
AUTHOR_CLIENT_URL=http://localhost:3000/author

# Cloudinary (File Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Nodemailer with Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=POVITAL <noreply@povital.com>

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OTP Configuration
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE=20971520
MAX_FILES_PER_UPLOAD=10

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Encryption
ENCRYPTION_KEY=your_32_character_encryption_key_here
ENCRYPTION_ALGORITHM=aes-256-cbc

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Payment Gateway (Future)
PAYMENT_GATEWAY_KEY=your_payment_gateway_key
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret

# Referral Configuration
REFERRAL_EARNING_AMOUNT=500
REFERRAL_CODE_LENGTH=8

# Auto-generated IDs Configuration
AUTHOR_ID_PREFIX=AUT
BOOK_ID_PREFIX=BK
TICKET_ID_PREFIX=TKT
TRANSACTION_ID_PREFIX=TXN

# PIN Code API (for address auto-fill)
PINCODE_API_URL=https://api.postalpincode.in/pincode
